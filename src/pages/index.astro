---
const target = "/es/";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0;url=${target}`} />
    <link rel="canonical" href={target} />
    <title>Redirecting...</title>
    <script is:inline>
      window.location.replace("/es/");
    </script>
  </head>
  <body>
    <a href={target}>Ir a /es</a>
  </body>
</html>
