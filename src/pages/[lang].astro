---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Focus from "../components/Focus.astro";
import Stack from "../components/Stack.astro";
import Projects from "../components/Projects.astro";
import Timeline from "../components/Timeline.astro";
import Contact from "../components/Contact.astro";
import { ContentStore, type Locale, Language } from "../data/content";

export function getStaticPaths() {
  return [{ params: { lang: Language.ES } }, { params: { lang: Language.EN } }];
}

const langParam = Astro.params.lang;
const lang: Locale = langParam === Language.EN ? Language.EN : Language.ES;
const { personal, skills, skillDomains, projects, timeline } = ContentStore.getPortfolioData(lang);
const ui = ContentStore.getUiCopy(lang);
---

<Layout title={ui.layout.pageTitlePrefix + personal.name} lang={lang}>
  <Hero personal={personal} lang={lang} />
  <Focus skills={skills} lang={lang} />
  <Stack domains={skillDomains} lang={lang} />
  <Projects projects={projects} lang={lang} />
  <Timeline items={timeline} lang={lang} />
  <Contact personal={personal} lang={lang} />
</Layout>
